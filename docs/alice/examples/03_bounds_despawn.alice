/**
 * This file demonstrates despawning entities that fall below screen bounds.
 * Shows how to access entity IDs and remove entities from the world.
 */

prop Position {
    x: Float, 
    y: Float,
}

/**
 * Query with filter and despawn:
 * - 'id: Id' captures the entity's identifier
 * - 'filter' excludes entities that don't match the condition
 * - 'despawn' removes the entity from the world
 */
in Update
query id: Id, pos: Position
filter pos.y < 0
despawn id